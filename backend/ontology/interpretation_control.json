{
  "confidence_components": [
    "feature_confidence",
    "literal_confidence",
    "scientific_evidence_strength",
    "ontology_coverage",
    "answer_stability",
    "conflict_penalty"
  ],
  "confidence_dynamics": {
    "time_decay": true,
    "saturation_function": "sigmoid",
    "reinforcement_policy": "outlier_boost"
  },
  "stop_conditions": {
    "stop_confidence_threshold": 0.8,
    "evidence_floor_requirement": 0.6,
    "max_question_limit": 20,
    "forced_stop_conditions": [
      "confidence_plateau_detected",
      "contradiction_loop_detected"
    ]
  }
}
