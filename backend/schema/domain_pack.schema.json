{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "domain_pack.schema.json",
  "title": "Domain Pack Metadata",
  "type": "object",
  "required": [
    "domain",
    "version",
    "input_schema",
    "ontology"
  ],
  "properties": {
    "domain": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "input_schema": {
      "type": "string"
    },
    "ontology": {
      "type": "object",
      "required": [
        "root_dir",
        "namespaces"
      ],
      "properties": {
        "root_dir": {
          "type": "string"
        },
        "namespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "pipeline": {
      "$ref": "domain_registry.schema.json#/$defs/pipelineConfig"
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "manifest_schema": {
          "type": "string"
        },
        "derived_schema": {
          "type": "string"
        },
        "inference_schema": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
