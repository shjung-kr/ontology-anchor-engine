{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "domain_registry.schema.json",
  "title": "Domain Registry",
  "type": "object",
  "required": [
    "version",
    "default_domain",
    "domains"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "default_domain": {
      "type": "string"
    },
    "domains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/domainConfig"
      }
    }
  },
  "$defs": {
    "domainConfig": {
      "type": "object",
      "required": [
        "title",
        "description",
        "version",
        "input_kind",
        "runner"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "input_kind": {
          "type": "string"
        },
        "runner": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_\\.]+:[a-zA-Z0-9_]+$"
        },
        "ontology_dir": {
          "type": "string"
        },
        "prompt_dir": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pipeline": {
          "$ref": "#/$defs/pipelineConfig"
        },
        "ontology_namespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "pipelineConfig": {
      "type": "object",
      "properties": {
        "parser": {
          "type": "string"
        },
        "validator": {
          "type": "string"
        },
        "llm_adapter": {
          "type": "string"
        },
        "feature_extractor": {
          "type": "string"
        },
        "state_builder": {
          "type": "string"
        },
        "proposal_evaluator": {
          "type": "string"
        },
        "artifact_writer": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
